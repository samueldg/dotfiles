{
  "cleanupPeriodDays": 90,
  "env": {
    "DISABLE_TELEMETRY": "1",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "LS",
      "Read",
      "Write",
      "Edit",
      "MultiEdit",
      "Glob",
      "Grep",
      "NotebookRead",
      "NotebookEdit",
      "Task",
      "TodoWrite",
      "WebFetch(domain:*)",
      "WebSearch",
      "Bash(cd:*)",
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(ls:*)",
      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs"
    ],
    "deny": [
      "Bash(git push:main)",
      "Bash(git push:master)",
      "Bash(git add -A:*)",
      "Bash(git add:.:*)"
    ]
  },
  "enableAllProjectMcpServers": false,
  "hooks": {},
  "enabledPlugins": {
    "decision-memo@delphia-plugins": true,
    "five-whys@delphia-plugins": true,
    "standalone-python-scripting@delphia-plugins": true,
    "code-review@claude-plugins-official": true,
    "notion-reader@delphia-plugins": true
  },
  "alwaysThinkingEnabled": true,
  "extraKnownMarketplaces": {
    "obsidian-skills": {
      "source": {
        "source": "github",
        "repo": "kepano/obsidian-skills"
      }
    }
  }
}
